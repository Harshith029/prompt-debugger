{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prompt-debugger.dev/schemas/knowledge-claims/v1",
  "title": "Claim Registry file v1",
  "description": "Dated, versioned registry of factual claims about provider behavior. Every taxonomy entry and technique cites claims; claims cite public URLs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["file_version", "claims"],
  "properties": {
    "file_version": { "const": 1 },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "claim", "url", "retrieved", "status", "last_verified"],
        "properties": {
          "id": { "type": "string", "pattern": "^clm-[a-z0-9-]+$" },
          "claim": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "pattern": "^https://", "minLength": 12 },
          "retrieved": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
            "description": "Date the source was first retrieved."
          },
          "status": {
            "type": "string",
            "enum": ["recorded", "verified", "stale", "retired"],
            "description": "recorded = captured, pending verification pass; verified = re-checked against the live source; stale = source changed, needs review; retired = no longer supported by any source."
          },
          "last_verified": {
            "type": ["string", "null"],
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "notes": { "type": ["string", "null"], "default": null }
        }
      }
    }
  }
}
