{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prompt-debugger.dev/schemas/knowledge-events/v1",
  "title": "Event Taxonomy file v1",
  "description": "Observable-event taxonomy for one provider. Each entry records what the user sees, the documented correlate, and — critically — what can and cannot be concluded.",
  "type": "object",
  "additionalProperties": false,
  "required": ["file_version", "taxonomy_version", "entries"],
  "properties": {
    "file_version": { "const": 1 },
    "taxonomy_version": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{2}(-[a-z0-9]+)?$"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "title",
          "user_sees",
          "surfaces",
          "api_correlate",
          "can_conclude",
          "cannot_conclude",
          "source_claims",
          "status"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^evt-[a-z0-9-]+$" },
          "kind": {
            "type": "string",
            "enum": [
              "refusal_message",
              "model_switch",
              "api_refusal_stop_reason",
              "api_fallback_block",
              "error",
              "unknown",
              "none"
            ],
            "description": "Must stay aligned with the Observable Event contract enum."
          },
          "title": { "type": "string", "minLength": 1 },
          "user_sees": {
            "type": "string",
            "minLength": 1,
            "description": "What appears on the user's screen or in the response payload."
          },
          "surfaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["claude_ai", "claude_code", "api", "other", "unspecified"]
            }
          },
          "api_correlate": {
            "type": ["string", "null"],
            "description": "The documented API mechanism this observation corresponds to, when one exists."
          },
          "can_conclude": { "type": "string", "minLength": 1 },
          "cannot_conclude": { "type": "string", "minLength": 1 },
          "source_claims": {
            "type": "array",
            "items": { "type": "string", "pattern": "^clm-[a-z0-9-]+$" }
          },
          "status": { "type": "string", "enum": ["draft", "active", "deprecated"] }
        }
      }
    }
  }
}
