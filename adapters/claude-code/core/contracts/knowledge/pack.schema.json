{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prompt-debugger.dev/schemas/knowledge-pack/v1",
  "title": "Knowledge Pack metadata v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["pack_id", "kind", "pack_version", "provider", "description"],
  "properties": {
    "pack_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "kind": { "type": "string", "enum": ["common", "provider"] },
    "pack_version": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{2}(-[a-z0-9]+)?$"
    },
    "provider": {
      "type": ["string", "null"],
      "description": "Provider identifier (e.g. 'anthropic'); null for the common pack."
    },
    "description": { "type": "string", "minLength": 1 }
  }
}
