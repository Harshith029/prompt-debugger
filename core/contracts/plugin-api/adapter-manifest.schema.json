{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prompt-debugger.dev/schemas/adapter-manifest/v1",
  "title": "Adapter Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["adapter_api_version", "name", "host", "adapter_version", "capabilities", "consumes"],
  "properties": {
    "adapter_api_version": { "const": 1 },
    "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "host": {
      "type": "string",
      "enum": ["claude-code", "cli", "mcp", "vscode", "web", "other"]
    },
    "adapter_version": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["analyze", "rewrite", "history", "visualize"] }
    },
    "consumes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_ir", "report", "rewrite_report", "observable_event", "storage", "knowledge"],
      "properties": {
        "prompt_ir": { "type": "integer", "minimum": 1 },
        "report": { "type": "integer", "minimum": 1 },
        "rewrite_report": { "type": "integer", "minimum": 1 },
        "observable_event": { "type": "integer", "minimum": 1 },
        "storage": { "type": "integer", "minimum": 1 },
        "knowledge": { "type": "integer", "minimum": 1 },
        "prompt_tree": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
